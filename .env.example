APP_NAME=
APP_PORT=8080
APP_ENV=development

GIN_MODE=debug

DB_HOST=localhost
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_SSLMODE=disable

# Goose migration tool (required for make migrate-* commands)
GOOSE_DRIVER=postgres
GOOSE_MIGRATION_DIR=./internal/app/db/migrations

# Test database (optional - falls back to DB_* above if not set)
# TEST_DB_HOST=localhost
# TEST_DB_PORT=5432
# TEST_DB_USER=
# TEST_DB_PASSWORD=
# TEST_DB_NAME=
# TEST_DB_SSLMODE=disable